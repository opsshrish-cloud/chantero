<section class="influencers" aria-labelledby="influencersHeading">
  <div class="influencers-inner">
    <div class="influencers-head r">
      <div>
        <span class="section-label"><span class="rule"></span>{{ section.settings.label | default: 'Chantèro in the Wild' }}</span>
        <h2 class="display-md" id="influencersHeading">{{ section.settings.heading | default: 'Real moments. Real rituals.' }}</h2>
      </div>
      {%- if section.settings.cta_label != blank -%}
        <a class="btn-text" href="{{ section.settings.cta_url | default: '#' }}" target="_blank" rel="noopener">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>

    <div class="creator-track">
      {%- for block in section.blocks -%}
        {%- if block.type == 'photo' -%}
          <a
            class="creator-card"
            href="{{ block.settings.link | default: '#' }}"
            target="_blank"
            rel="noopener"
            aria-label="{{ block.settings.handle | default: 'View on Instagram' }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 500
                | image_tag:
                  class: 'creator-card-img',
                  loading: 'lazy',
                  alt: block.settings.handle | default: 'Community photo',
                  width: 500,
                  height: 660
              }}
            {%- elsif block.settings.image_asset != blank -%}
              <img
                src="{{ block.settings.image_asset | asset_url }}"
                alt="{{ block.settings.handle | default: 'Community photo' }}"
                class="creator-card-img"
                loading="lazy"
                width="500"
                height="660"
              />
            {%- endif -%}
            <div class="creator-card-overlay"></div>
            {%- if block.settings.handle != blank -%}
              <div class="creator-card-info">
                <span class="creator-handle">{{ block.settings.handle }}</span>
              </div>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="r" style="text-align:center;margin-top:28px;">
        <a class="btn-text" href="{{ section.settings.cta_url | default: '#' }}" target="_blank" rel="noopener">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Influencers / Community",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Chantèro in the Wild"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real moments. Real rituals."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "See more on Instagram"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Community photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "Image filename in assets",
          "placeholder": "community-01.jpg"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Instagram handle",
          "default": "@chantero.in"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Influencers",
      "blocks": [
        { "type": "photo", "settings": { "image_asset": "community-01.jpg", "handle": "@chantero.in" } },
        { "type": "photo", "settings": { "image_asset": "community-02.jpg", "handle": "@chantero.in" } },
        { "type": "photo", "settings": { "image_asset": "community-03.jpg", "handle": "@chantero.in" } },
        { "type": "photo", "settings": { "image_asset": "community-04.jpg", "handle": "@chantero.in" } },
        { "type": "photo", "settings": { "image_asset": "community-05.jpg", "handle": "@chantero.in" } }
      ]
    }
  ]
}
{% endschema %}
