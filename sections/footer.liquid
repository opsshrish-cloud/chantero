<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-body">

      <!-- Brand column -->
      <div class="footer-brand">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 280
            | image_tag:
              loading: 'lazy',
              class: 'footer-logo-img',
              alt: shop.name,
              width: 140,
              height: 20
          }}
        {%- else -%}
          <img
            src="{{ 'logo-wordmark.svg' | asset_url }}"
            alt="{{ shop.name }}"
            class="footer-logo-img"
            loading="lazy"
            width="140"
            height="20"
          />
        {%- endif -%}

        {%- if section.settings.tagline != blank -%}
          <p class="footer-tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}

        <div class="footer-social" aria-label="{{ 'general.accessibility.social_media' | t | default: 'Social media' }}">
          {%- if settings.instagram_url != blank -%}
            <a class="footer-social-link" href="{{ settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.youtube_url != blank -%}
            <a class="footer-social-link" href="{{ settings.youtube_url }}" target="_blank" rel="noopener" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-1.96C18.88 4 12 4 12 4s-6.88 0-8.6.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.94 1.94C5.12 20 12 20 12 20s6.88 0 8.6-.48a2.78 2.78 0 001.94-1.94A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.whatsapp_number != blank -%}
            <a class="footer-social-link" href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}" target="_blank" rel="noopener" aria-label="WhatsApp">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Nav columns from blocks -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_column' -%}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <span class="footer-col-label">{{ block.settings.heading }}</span>
            {%- assign col_menu = linklists[block.settings.menu] -%}
            {%- if col_menu.links.size > 0 -%}
              <nav class="footer-nav">
                {%- for link in col_menu.links -%}
                  <a href="{{ link.url }}">{{ link.title }}</a>
                {%- endfor -%}
              </nav>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div><!-- /footer-body -->

    <div class="footer-bottom">
      <p class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="footer-bottom-links">
        {%- for policy in shop.policies -%}
          <a href="{{ policy.url }}">{{ policy.title }}</a>
        {%- endfor -%}
      </div>
    </div>

  </div>

  <!-- WhatsApp FAB -->
  {%- if settings.whatsapp_number != blank -%}
    <a
      class="wa-fab"
      href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: ' ' | remove: '-' }}"
      target="_blank"
      rel="noopener"
      aria-label="Chat on WhatsApp"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  {%- endif -%}

</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "French-formulated fragrances designed for daily signatures, thoughtful gifting and discovery-led buying."
    }
  ],
  "blocks": [
    {
      "type": "nav_column",
      "name": "Navigation column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Fragrances"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "nav_column", "settings": { "heading": "Fragrances", "menu": "footer-fragrances" } },
        { "type": "nav_column", "settings": { "heading": "Experience", "menu": "footer-experience" } },
        { "type": "nav_column", "settings": { "heading": "Support", "menu": "footer-support" } }
      ]
    }
  ]
}
{% endschema %}
