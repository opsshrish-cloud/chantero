<div class="ann" role="region" aria-label="{{ 'sections.announcement_bar.label' | t | default: 'Announcements' }}">
  <div class="ann-slider">
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' and block.settings.message != blank -%}
        <div class="ann-slide{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}">{{ block.settings.message }}</a>
          {%- else -%}
            {{ block.settings.message }}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  {%- if section.blocks.size > 1 -%}
    <div class="ann-dots" aria-hidden="true">
      {%- for block in section.blocks -%}
        {%- if block.type == 'slide' and block.settings.message != blank -%}
          <button class="ann-dot{% if forloop.first %} active{% endif %}"></button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Announcement bar",
  "tag": "div",
  "class": "ann-wrap",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "text",
          "id": "message",
          "label": "Message",
          "default": "Complimentary shipping above ₹6,500"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "slide", "settings": { "message": "Complimentary shipping above ₹6,500" } },
        { "type": "slide", "settings": { "message": "Try Before You Commit — Redeem Your Discovery Set on Any 100ml Bottle" } },
        { "type": "slide", "settings": { "message": "Parfums • 24% Perfume Oil Concentration" } }
      ]
    }
  ]
}
{% endschema %}
