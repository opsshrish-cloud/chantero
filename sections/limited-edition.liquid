<section class="velvet" id="velvet">

  <div class="velvet-img-side">
    {%- if section.settings.bg_image != blank -%}
      {{
        section.settings.bg_image
        | image_url: width: 1000
        | image_tag:
          loading: 'lazy',
          class: 'velvet-img',
          alt: section.settings.bg_image.alt | escape | default: section.settings.collab_name,
          widths: '600, 900, 1200'
      }}
    {%- endif -%}
    <div class="velvet-img-veil"></div>
    {%- if section.settings.bottle_image != blank -%}
      {{
        section.settings.bottle_image
        | image_url: width: 500
        | image_tag:
          loading: 'lazy',
          class: 'velvet-product-pin',
          alt: 'Velvet bottle',
          widths: '300, 500, 700'
      }}
    {%- endif -%}
  </div>

  <div class="velvet-text-side">
    <div class="velvet-content">

      <div class="velvet-badges r">
        {%- for i in (1..3) -%}
          {%- assign badge_id = 'badge' | append: i -%}
          {%- if section.settings[badge_id] != blank -%}
            <span class="velvet-badge">{{ section.settings[badge_id] }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.collab_name != blank -%}
        <p class="velvet-collab r d1">{{ section.settings.collab_name }}</p>
      {%- endif -%}

      <h2 class="velvet-title r d1">{{ section.settings.title }}</h2>

      {%- if section.settings.by_line != blank -%}
        <p class="velvet-by r d2">{{ section.settings.by_line }}</p>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="velvet-desc r d2">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="velvet-notes-row r d3">
        {%- assign notes = section.settings.scent_notes | split: ',' -%}
        {%- for note in notes -%}
          <span class="velvet-note">{{ note | strip }}</span>
        {%- endfor -%}
      </div>

      <div class="velvet-footer r d3">
        {%- if section.settings.product != blank -%}
          {%- assign velvet_p = all_products[section.settings.product] -%}
          <div class="velvet-price">{{ velvet_p.price_min | money }}</div>
          <div style="display:flex;gap:14px;flex-wrap:wrap;">
            <a href="{{ velvet_p.url }}" class="btn btn-outline-gold">Shop {{ velvet_p.title }}</a>
            {%- if section.settings.sampler_url != blank -%}
              <a href="{{ section.settings.sampler_url }}" class="btn btn-outline">Try 3ml Sampler</a>
            {%- endif -%}
          </div>
        {%- else -%}
          {%- if section.settings.price_text != blank -%}
            <div class="velvet-price">{{ section.settings.price_text }}</div>
          {%- endif -%}
          <div style="display:flex;gap:14px;flex-wrap:wrap;">
            {%- if section.settings.cta_url != blank -%}
              <a href="{{ section.settings.cta_url }}" class="btn btn-outline-gold">{{ section.settings.cta_label | default: 'Shop Velvet' }}</a>
            {%- endif -%}
            {%- if section.settings.sampler_url != blank -%}
              <a href="{{ section.settings.sampler_url }}" class="btn btn-outline">Try 3ml Sampler</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Limited Edition",
  "tag": "div",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product (for live price)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "image_picker",
      "id": "bottle_image",
      "label": "Bottle pin image"
    },
    {
      "type": "text",
      "id": "badge1",
      "label": "Badge 1",
      "default": "Limited Edition"
    },
    {
      "type": "text",
      "id": "badge2",
      "label": "Badge 2",
      "default": "Collaboration"
    },
    {
      "type": "text",
      "id": "badge3",
      "label": "Badge 3",
      "default": "Available"
    },
    {
      "type": "text",
      "id": "collab_name",
      "label": "Collaboration name",
      "default": "Chantèro × Dr. Mickey Mehta"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Velvet"
    },
    {
      "type": "text",
      "id": "by_line",
      "label": "By-line",
      "default": "Where French perfumery meets ancient Indian wisdom"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Co-created with wellness visionary Dr. Mickey Mehta, Velvet is a rare convergence — Grasse-formulated, Ayurveda-inspired. A luxury fragrance that quiets the mind and anchors the spirit."
    },
    {
      "type": "text",
      "id": "scent_notes",
      "label": "Scent notes (comma-separated)",
      "default": "Bergamot, Lavender, Cardamom, Patchouli, Vetiver, Tonka Bean"
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Price text (if no product selected)",
      "default": "₹2,800"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Shop CTA URL (if no product selected)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Shop CTA label",
      "default": "Shop Velvet"
    },
    {
      "type": "url",
      "id": "sampler_url",
      "label": "Sampler product URL"
    }
  ],
  "presets": [
    {
      "name": "Limited Edition"
    }
  ]
}
{% endschema %}
