<section class="gifts" id="gifting" aria-labelledby="giftsHeading">
  <div class="gifts-inner">
    <div class="gifts-head">
      <div>
        <span class="section-label r"><span class="rule"></span>{{ section.settings.label | default: 'Gifting' }}</span>
        <h2 class="display-lg r d1" id="giftsHeading">{{ section.settings.heading | default: 'A gift that feels chosen, not rushed.' }}</h2>
      </div>
      {%- if section.settings.cta_label != blank -%}
        <a class="btn btn-outline r d2" href="{{ section.settings.cta_url | default: routes.collections_url }}">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>

    <div class="gifts-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'gift_card' -%}
          {%- assign delay = 'd' | append: forloop.index0 -%}
          <article class="gift-card r {{ delay }}" {{ block.shopify_attributes }}>
            <div class="gift-card-img-wrap">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 600
                  | image_tag:
                    class: 'gift-card-img',
                    loading: 'lazy',
                    alt: block.settings.image.alt | default: block.settings.name,
                    width: 600,
                    height: 600
                }}
              {%- elsif block.settings.image_asset != blank -%}
                <img
                  src="{{ block.settings.image_asset | asset_url }}"
                  alt="{{ block.settings.name }}"
                  class="gift-card-img"
                  loading="lazy"
                  width="600"
                  height="600"
                />
              {%- endif -%}
            </div>
            <span class="gift-card-label">{{ block.settings.subtitle }}</span>
            <h3 class="gift-card-name">{{ block.settings.name }}</h3>
            <p class="gift-card-desc">{{ block.settings.description }}</p>
            <span class="gift-card-price">
              {%- if block.settings.product != blank -%}
                {%- assign gift_prod = all_products[block.settings.product] -%}
                {%- if gift_prod != blank -%}
                  {{ gift_prod.price_min | money }}
                {%- endif -%}
              {%- else -%}
                {{ block.settings.price_text }}
              {%- endif -%}
            </span>
            {%- if block.settings.link != blank -%}
              <a class="btn-text" href="{{ block.settings.link }}" style="display:inline-flex;margin-top:16px;">Shop now</a>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.note != blank -%}
      <div style="text-align:center;margin-top:32px;" class="r">
        <p class="body-sm" style="margin-bottom:16px;">{{ section.settings.note }}</p>
        {%- if section.settings.bottom_cta_label != blank -%}
          <a class="btn btn-outline" href="{{ section.settings.bottom_cta_url | default: '#' }}">{{ section.settings.bottom_cta_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gift Experience",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Gifting"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A gift that feels chosen, not rushed."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Header CTA label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Header CTA link"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Bottom note",
      "default": "Add a note, choose wrapping and make the order feel personal."
    },
    {
      "type": "text",
      "id": "bottom_cta_label",
      "label": "Bottom CTA label",
      "default": "Explore Gifting"
    },
    {
      "type": "url",
      "id": "bottom_cta_url",
      "label": "Bottom CTA link"
    }
  ],
  "blocks": [
    {
      "type": "gift_card",
      "name": "Gift card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "Image filename in assets",
          "placeholder": "gift-box-standard.jpg"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Signature choice"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Signature Gift Box"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A full-size Chantèro fragrance presented with refined packaging and space for a personal note."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product (for price)"
        },
        {
          "type": "text",
          "id": "price_text",
          "label": "Price text (fallback)",
          "default": "From ₹3,200"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gift Experience",
      "blocks": [
        { "type": "gift_card", "settings": { "image_asset": "gift-box-standard.jpg", "subtitle": "Signature choice", "name": "Signature Gift Box", "description": "A full-size Chantèro fragrance presented with refined packaging and space for a personal note.", "price_text": "From ₹3,200" } },
        { "type": "gift_card", "settings": { "image_asset": "gift-box-grande.png", "subtitle": "For two", "name": "The Duo", "description": "Two complementary signatures in one elevated set. Ideal for celebrations, weddings and shared rituals.", "price_text": "From ₹5,800" } },
        { "type": "gift_card", "settings": { "image_asset": "gift-box-petite.png", "subtitle": "Safest gift", "name": "Discovery Gift Set", "description": "A discovery set for the person who wants to experience each scent before selecting their bottle.", "price_text": "₹500" } }
      ]
    }
  ]
}
{% endschema %}
