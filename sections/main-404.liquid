<div class="not-found-wrap wrap" style="text-align:center;padding:var(--pad) 0;">
  <p class="label" style="display:block;margin-bottom:20px;">404</p>
  <h1 class="display-md r" style="margin-bottom:24px;">Page not found</h1>
  <p class="r d1" style="color:var(--muted);margin-bottom:40px;">
    The page you're looking for has been moved, deleted, or never existed.
  </p>
  <a href="{{ routes.root_url }}" class="btn btn-gold r d2">Back to Home</a>
</div>

{% schema %}
{
  "name": "404",
  "tag": "div"
}
{% endschema %}
