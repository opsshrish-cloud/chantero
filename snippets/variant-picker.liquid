{%- comment -%}
  Variant picker — renders size tiles and updates hidden form input.
  Usage: {% render 'variant-picker', product: product %}
{%- endcomment -%}

{%- if product.variants.size > 1 -%}
<div class="pd-sec-label" id="size-label">
  Select size
</div>

<div
  class="sizes"
  role="group"
  aria-labelledby="size-label"
>
  {%- for variant in product.variants -%}
    <div
      class="size-tile{% if variant == product.selected_or_first_available_variant %} active{% endif %}{% unless variant.available %} sold-out{% endunless %}"
      data-variant-id="{{ variant.id }}"
      data-price="{{ variant.price }}"
      data-price-formatted="{{ variant.price | money }}"
      data-compare-price="{{ variant.compare_at_price }}"
      data-compare-price-formatted="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
      data-available="{{ variant.available }}"
      data-sold-out="{% unless variant.available %}true{% else %}false{% endunless %}"
      role="radio"
      aria-checked="{% if variant == product.selected_or_first_available_variant %}true{% else %}false{% endif %}"
      aria-label="{{ variant.option1 }}{% if variant.option2 %} / {{ variant.option2 }}{% endif %}"
      tabindex="0"
    >
      <div class="size-ml">{{ variant.option1 | remove: 'ml' | remove: 'ML' }}</div>
      <div class="size-unit">ml EDP</div>
      <div class="size-price">{{ variant.price | money }}</div>
    </div>
  {%- endfor -%}
</div>
{%- endif -%}
